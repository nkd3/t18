# ---------- HTTP wire taps (requests + httpx) ----------
# requests tap
try:
    import requests
    _REQ_ORIG = requests.Session.request
    def _REQ_WRAP(self, method, url, *a, **kw):
        if "api.notion.com" in str(url):
            logging.info(f"[HTTP][{method}] {url}")
            try:
                resp = _REQ_ORIG(self, method, url, *a, **kw)
                logging.info(f"[HTTP][{method}] -> {resp.status_code} {getattr(resp, 'reason', '')}")
                body = getattr(resp, "text", "")
                if body:
                    logging.info("[HTTP][body<=2KB] " + body[:2048].replace("\r"," ").replace("\n"," "))
                return resp
            except Exception as e:
                logging.exception(f"[HTTP][{method}] RAISED: {e}")
                raise
        return _REQ_ORIG(self, method, url, *a, **kw)
    requests.Session.request = _REQ_WRAP
    logging.info("[HTTP] requests tap installed")
except Exception:
    pass

# httpx tap (covers libraries that use httpx)
try:
    import httpx
    _HX_C_REQ  = httpx.Client.request
    _HX_A_REQ  = httpx.AsyncClient.request
    _HX_FUNC   = httpx.request

    def _log_body(prefix, body):
        if body:
            logging.info(f"{prefix}[body<=2KB] " + body[:2048].replace("\r"," ").replace("\n"," "))

    def _HX_WRAP_SYNC(self, method, url, *a, **kw):
        if "api.notion.com" in str(url):
            logging.info(f"[HTTPX][{method}] {url}")
            try:
                r = _HX_C_REQ(self, method, url, *a, **kw)
                logging.info(f"[HTTPX][{method}] -> {r.status_code} {getattr(r, 'reason_phrase', '')}")
                _log_body("[HTTPX] ", getattr(r, "text", ""))
                return r
            except Exception as e:
                logging.exception(f"[HTTPX][{method}] RAISED: {e}")
                raise
        return _HX_C_REQ(self, method, url, *a, **kw)

    async def _HX_WRAP_ASYNC(self, method, url, *a, **kw):
        if "api.notion.com" in str(url):
            logging.info(f"[AHTTPX][{method}] {url}")
            try:
                r = await _HX_A_REQ(self, method, url, *a, **kw)
                logging.info(f"[AHTTPX][{method}] -> {r.status_code} {getattr(r, 'reason_phrase', '')}")
                _log_body("[AHTTPX] ", getattr(r, "text", ""))
                return r
            except Exception as e:
                logging.exception(f"[AHTTPX][{method}] RAISED: {e}")
                raise
        return await _HX_A_REQ(self, method, url, *a, **kw)

    def _HX_WRAP_FUNC(method, url, *a, **kw):
        if "api.notion.com" in str(url):
            logging.info(f"[HTTPX-FUNC][{method}] {url}")
            try:
                r = _HX_FUNC(method, url, *a, **kw)
                logging.info(f"[HTTPX-FUNC][{method}] -> {r.status_code} {getattr(r, 'reason_phrase', '')}")
                _log_body("[HTTPX-FUNC] ", getattr(r, "text", ""))
                return r
            except Exception as e:
                logging.exception(f"[HTTPX-FUNC][{method}] RAISED: {e}")
                raise
        return _HX_FUNC(method, url, *a, **kw)

    httpx.Client.request      = _HX_WRAP_SYNC
    httpx.AsyncClient.request = _HX_WRAP_ASYNC
    httpx.request             = _HX_WRAP_FUNC
    logging.info("[HTTPX] httpx taps installed")
except Exception:
    pass
